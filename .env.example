# =========================
# DATABASE CONFIGURATION
# =========================

# Database name
POSTGRES_DB=auth

# Database username
POSTGRES_USER=postgres

# Database password (change in production!)
POSTGRES_PASSWORD=your_password_here


# Spring datasource (used by auth-api)
# Format: jdbc:postgresql://<host>:<port>/<db>
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/auth
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here


# =========================
# JWT CONFIGURATION
# =========================

# Secret key for signing JWT tokens (min 32 chars recommended)
JWT_SECRET=your_jwt_secret_here

# Token expiration in milliseconds (e.g. 1h = 3600000)
JWT_EXPIRATION=3600000


# =========================
# INTERNAL SECURITY
# =========================

# Token for internal service-to-service communication
INTERNAL_TOKEN=your_internal_token_here


# =========================
# SERVICE COMMUNICATION
# =========================

# URL of data-api service (used by auth-api)
SERVICE_B_URL=http://data-api:8081


# =========================
# PORTS
# =========================

# External port for auth-api
AUTH_API_PORT=8080

# External port for data-api
DATA_API_PORT=8081